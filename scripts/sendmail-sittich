#!/bin/sh

set -eu

API_URL="${API_URL:-https://localhost:5092/transcribe}"
API_OPTS="${API_OPTS:-}"
CURL_OPTS="${CURL_OPTS:--k}"

ORIG_PWD=$(pwd)
TMPDIR=$(mktemp -d)

cleanup() {
	cd "$ORIG_PWD" 2>/dev/null || true
	rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

cd "$TMPDIR"

cat > stream.org

if grep -iq '^X-Sittich-Processed: true' stream.org; then
	sendmail -t < stream.org
	exit 0
fi

BOUNDARY=$(grep -im1 'boundary=' stream.org | sed 's/.*boundary="\{0,1\}\([^";[:space:]]*\).*/\1/')

if [ -z "$BOUNDARY" ]; then
	sed '1a X-Sittich-Processed: true' stream.org > stream.new
else
	awk '/'"$BOUNDARY"'/{i++}{print > "stream.part"i}' stream.org

	if [ ! -f stream.part3 ]; then
		sed '1a X-Sittich-Processed: true' stream.org > stream.new
	else
		sed '1,6d' stream.part3 | tr -d '\r ' | base64 -di > stream.part3.wav

		TRANSCRIPT=""
		if [ -s stream.part3.wav ]; then
			CURL_RC=0
			sh -c "curl -sS $CURL_OPTS -X POST \"$API_URL\" -F file=@stream.part3.wav $API_OPTS" > curl.out 2>curl.err || CURL_RC=$?
			if [ $CURL_RC -eq 0 ]; then
				RESPONSE=$(cat curl.out 2>/dev/null || true)
				TRANSCRIPT=$(printf '%s' "$RESPONSE" | iconv -f UTF-8 -t ISO-8859-1//TRANSLIT)
			else
				TRANSCRIPT=""
			fi
		else
			TRANSCRIPT=""
		fi

		sed '1a X-Sittich-Processed: true' stream.part > stream.new
		cat stream.part1 >> stream.new
		cat stream.part2 >> stream.new

		if [ -n "$TRANSCRIPT" ]; then
			printf '\n\n' >> stream.new
			echo "--- Transkript ---" >> stream.new
			echo "$TRANSCRIPT" >> stream.new
			printf '\n' >> stream.new
		fi

		cat stream.part3 >> stream.new
		tr -d '\r' < stream.part4 >> stream.new
	fi
fi

sendmail -t < stream.new
